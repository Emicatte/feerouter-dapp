# ═══════════════════════════════════════════════════════════════
#  RPagos Backend Core — Environment Configuration
# ═══════════════════════════════════════════════════════════════

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://rpagos_user:your_password@localhost:5432/rpagos_compliance

# HMAC Secret — usato per validare x_signature dai callback
HMAC_SECRET=change-me-in-production-use-64-char-hex

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# DAC8 Reporting
DAC8_REPORTING_ENTITY_NAME="RPagos S.r.l."
DAC8_REPORTING_ENTITY_TIN="IT12345678901"
DAC8_REPORTING_COUNTRY="IT"
DAC8_FISCAL_YEAR=2025

# Anomaly Detection thresholds
ANOMALY_Z_SCORE_THRESHOLD=3.0
ANOMALY_MIN_SAMPLE_SIZE=10
