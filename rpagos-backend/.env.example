# ═══════════════════════════════════════════════════════════════
#  RSend Backend — Environment Variables
#
#  Copy to .env and fill in values.
#  Variables marked [REQUIRED] will cause a startup error if empty.
#  Variables marked [REQUIRED in prod] are only enforced when DEBUG=false.
# ═══════════════════════════════════════════════════════════════

# ── Database [REQUIRED] ─────────────────────────────────────
# Async PostgreSQL connection string.
# Dev:  sqlite+aiosqlite:///./rsend_dev.db
# Prod: postgresql+asyncpg://user:pass@host:5432/rsend
DATABASE_URL=postgresql+asyncpg://rpagos:password@localhost:5432/rpagos

# ── Redis [REQUIRED in prod] ────────────────────────────────
# Used for cache, rate limiting, WebSocket event buffer,
# Celery broker, and NonceManager (atomic nonce allocation).
REDIS_URL=redis://localhost:6379/0

# ── Alchemy [REQUIRED] ──────────────────────────────────────
# API key for RPC calls (eth_gasPrice, eth_sendRawTransaction, etc.)
# ⚠️  Senza questo, NESSUN sweep può essere eseguito!
# Get one at: https://dashboard.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Webhook signing secret (from Alchemy Dashboard > Webhooks).
# If empty, backend falls back to block polling (slower, higher RPC usage).
ALCHEMY_WEBHOOK_SECRET=your_webhook_hmac_secret

# Auth token for Alchemy Notify API (manage webhooks programmatically).
ALCHEMY_AUTH_TOKEN=

# ── Sweep Signer [REQUIRED] ─────────────────────────────────
# Private key for the hot wallet that executes sweep transactions.
# Must be a valid 0x-prefixed 64-char hex string (32 bytes).
# ⚠️  Questo wallet DEVE avere ETH per il gas!
# ⚠️  In produzione, usa SIGNER_MODE=kms e KMS_KEY_ID
# WARNING: This key controls funds. Never commit it to git.
SIGNER_MODE=local
SWEEP_PRIVATE_KEY=your_private_key_hex

# AWS KMS key ID (only if SIGNER_MODE=kms). Must be ECC_SECG_P256K1.
KMS_KEY_ID=
AWS_REGION=eu-west-1

# ── Deposit Address Key [REQUIRED] ──────────────────────────
# Master private key per derivazione deposit addresses.
# Ogni payment intent ottiene un indirizzo unico derivato da questa chiave.
# CRITICO: backup sicuro — se persa, i fondi nei deposit address non sono recuperabili!
# Formato: 0x-prefixed 64-char hex string (32 bytes)
# Generare con: python3 -c "from eth_account import Account; print(Account.create().key.hex())"
DEPOSIT_MASTER_KEY=0x_your_deposit_master_key_here

# ── Security [REQUIRED in prod] ─────────────────────────────
# HMAC secret for webhook signature verification.
# Must be >= 32 characters in production.
HMAC_SECRET=change-me-in-production

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Set to true for development (enables Swagger UI, hot reload, verbose logs).
# MUST be false in production — controls CORS, docs exposure, and validation strictness.
DEBUG=false

# ── CORS Origins ─────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Ignored when DEBUG=true (localhost:3000 and localhost:5173 are auto-allowed).
CORS_ORIGINS=https://rsends.io,https://www.rsends.io

# ── Celery ───────────────────────────────────────────────────
# Broker and result backend for Celery task queue.
# Should be different Redis DBs than REDIS_URL to avoid key collisions.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── DAC8 Compliance ──────────────────────────────────────────
# EU DAC8 crypto-asset reporting entity details.
DAC8_REPORTING_ENTITY_NAME=RSends S.r.l.
DAC8_REPORTING_ENTITY_TIN=IT12345678901
DAC8_REPORTING_COUNTRY=IT
DAC8_FISCAL_YEAR=2025

# ── Anomaly Detection ───────────────────────────────────────
# Z-score threshold for flagging anomalous transactions.
ANOMALY_Z_SCORE_THRESHOLD=3.0
ANOMALY_MIN_SAMPLE_SIZE=10

# ── Notifications (opzionale) ───────────────────────────────
# Bot token and chat ID for sweep status alerts.
# Leave empty to disable Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Rate limiting for notification messages (per chat).
NOTIFICATION_RATE_LIMIT=30
NOTIFICATION_RATE_WINDOW=60

# ── Monitoring (opzionale) ──────────────────────────────────
# Sentry DSN for error tracking. Leave empty to disable.
SENTRY_DSN=
