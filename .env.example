# ═══════════════════════════════════════════════════════════
# Web3 Wallet Connect — Environment Variables
# Copy this file to .env.local and fill in the values.
# ═══════════════════════════════════════════════════════════

# ── WalletConnect ──────────────────────────────────────────
# Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ── RPC Endpoints (optional — falls back to public RPCs) ──
NEXT_PUBLIC_RPC_ETHEREUM=
NEXT_PUBLIC_RPC_BASE=
NEXT_PUBLIC_RPC_ARBITRUM=
NEXT_PUBLIC_RPC_OPTIMISM=
NEXT_PUBLIC_RPC_POLYGON=
NEXT_PUBLIC_RPC_BNB=
NEXT_PUBLIC_RPC_AVALANCHE=
NEXT_PUBLIC_RPC_CELO=
NEXT_PUBLIC_RPC_BLAST=
NEXT_PUBLIC_RPC_ZKSYNC=
NEXT_PUBLIC_RPC_BASE_SEPOLIA=

# ── Alchemy API Key (optional — for enhanced RPC) ─────────
# Used by both frontend (wagmi transports + gas widget) and backend
ALCHEMY_API_KEY=
NEXT_PUBLIC_ALCHEMY_API_KEY=

# ── Infura API Key (optional — secondary RPC fallback) ────
NEXT_PUBLIC_INFURA_API_KEY=

# ── Default Chain ──────────────────────────────────────────
# 1 = Ethereum, 8453 = Base, 42161 = Arbitrum, 84532 = Base Sepolia
NEXT_PUBLIC_TARGET_CHAIN_ID=8453

# ── Backend API URL (RPagos backend) ──────────────────────
# Server-side URL used by Next.js API routes (not exposed to browser)
RPAGOS_BACKEND_URL=http://localhost:8000
# Public URL (exposed to browser — only for direct client calls, if any)
NEXT_PUBLIC_RPAGOS_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Fee Router Contract Addresses ──────────────────────────
NEXT_PUBLIC_FEE_ROUTER_V4_BASE=
NEXT_PUBLIC_FEE_ROUTER_V4_BASE_SEPOLIA=

# ── Oracle / Signer Keys (server-side only) ────────────────
ORACLE_PRIVATE_KEY=
COMPLIANCE_SIGNER_PRIVATE_KEY=

# ── HMAC Secret (for webhook verification) ─────────────────
# Server-only. Used by app/api/tx/callback/route.ts (proxy) to sign payloads
# before forwarding to rpagos-backend. NEVER expose with NEXT_PUBLIC_ prefix.
# Must match HMAC_SECRET in rpagos-backend/.env
HMAC_SECRET=

# ── Dati legali emittente (ricevuta PDF) ───────────────────
NEXT_PUBLIC_COMPANY_NAME=RSend S.r.l.
NEXT_PUBLIC_COMPANY_VAT=IT______________
NEXT_PUBLIC_COMPANY_ADDRESS=(sede legale da configurare)
NEXT_PUBLIC_COMPANY_PEC=

# ── Admin Dashboard ────────────────────────────────────────
# Secret token for /admin/* dashboard access.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# ── CoinGecko Demo API key ─────────────────────────────────
# Get yours free at: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=your_key_here
NEXT_PUBLIC_COINGECKO_API_KEY=your_key_here

# ── Database (backend) ─────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ── End-user Auth (Google OAuth via NextAuth) ─────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client (Web)
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL of this Next.js app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
