# ═══════════════════════════════════════════════════════════
# Web3 Wallet Connect — Environment Variables
# Copy this file to .env.local and fill in the values.
# ═══════════════════════════════════════════════════════════

# ── WalletConnect ──────────────────────────────────────────
# Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=

# ── RPC Endpoints (optional — falls back to public RPCs) ──
NEXT_PUBLIC_RPC_ETHEREUM=
NEXT_PUBLIC_RPC_BASE=
NEXT_PUBLIC_RPC_ARBITRUM=
NEXT_PUBLIC_RPC_OPTIMISM=
NEXT_PUBLIC_RPC_POLYGON=
NEXT_PUBLIC_RPC_BNB=
NEXT_PUBLIC_RPC_AVALANCHE=
NEXT_PUBLIC_RPC_CELO=
NEXT_PUBLIC_RPC_BLAST=
NEXT_PUBLIC_RPC_ZKSYNC=
NEXT_PUBLIC_RPC_BASE_SEPOLIA=

# ── Alchemy API Key (optional — for enhanced RPC) ─────────
ALCHEMY_API_KEY=

# ── Default Chain ──────────────────────────────────────────
# 1 = Ethereum, 8453 = Base, 42161 = Arbitrum, 84532 = Base Sepolia
NEXT_PUBLIC_TARGET_CHAIN_ID=8453

# ── Backend API URL (RPagos backend) ──────────────────────
NEXT_PUBLIC_RPAGOS_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Fee Router Contract Addresses ──────────────────────────
NEXT_PUBLIC_FEE_ROUTER_V4_BASE=
NEXT_PUBLIC_FEE_ROUTER_V4_BASE_SEPOLIA=

# ── Oracle / Signer Keys (server-side only) ────────────────
ORACLE_PRIVATE_KEY=
COMPLIANCE_SIGNER_PRIVATE_KEY=

# ── HMAC Secret (for webhook verification) ─────────────────
NEXT_PUBLIC_HMAC_SECRET=

# ── Database (backend) ─────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./dev.db
